          </div>
        </article>

      </div>
    </div>
  </section>

  <footer>
    <div class="container">
      <p>&copy; 2026 CreatorOS. All Rights Reserved.</p>
    </div>
  </footer>
</div>

<script>
  // Tab switching
  function switchTab(type, btn) {
    document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    document.querySelectorAll('.scard').forEach(card => {
      const status = card.dataset.status;
      if (type === 'all') {
        card.style.display = 'flex';
        setTimeout(() => card.style.opacity = (status === 'available' ? '1' : '0.7'), 10);
      } else if (type === 'active') {
        if (status === 'available') {
          card.style.display = 'flex';
          setTimeout(() => card.style.opacity = '1', 10);
        } else {
          card.style.opacity = '0';
          setTimeout(() => card.style.display = 'none', 200);
        }
      } else {
        if (status !== 'available') {
          card.style.display = 'flex';
          setTimeout(() => card.style.opacity = '0.7', 10);
        } else {
          card.style.opacity = '0';
          setTimeout(() => card.style.display = 'none', 200);
        }
      }
    });
  }

  // 3D mouse tilt on hero panel
  const heroPanel = document.getElementById('heroPanel');
  heroPanel.addEventListener('mousemove', e => {
    const r = heroPanel.getBoundingClientRect();
    const x = (e.clientX - r.left) / r.width - 0.5;
    const y = (e.clientY - r.top) / r.height - 0.5;
    heroPanel.style.transform = `rotateY(${x * 8}deg) rotateX(${-y * 6}deg) translateZ(0)`;
  });
  heroPanel.addEventListener('mouseleave', () => {
    heroPanel.style.transform = '';
  });

  // Ecosystem panel subtle parallax
  const ecoPanel = document.getElementById('ecoPanel');
  ecoPanel.addEventListener('mousemove', e => {
    const r = ecoPanel.getBoundingClientRect();
    const x = (e.clientX - r.left) / r.width - 0.5;
    const y = (e.clientY - r.top) / r.height - 0.5;
    ecoPanel.style.transform = `rotateY(${x * 5}deg) rotateX(${-y * 4}deg)`;
  });
  ecoPanel.addEventListener('mouseleave', () => {
    ecoPanel.style.transform = '';
  });

  // Scroll-based fade-in for service cards
  const observer = new IntersectionObserver(entries => {
    entries.forEach((entry, i) => {
      if (entry.isIntersecting) {
        setTimeout(() => {
          entry.target.style.opacity = entry.target.classList.contains('coming_soon') ? '0.7' : '1';
          entry.target.style.transform = 'translateY(0)';
        }, i * 80);
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.1 });

  document.querySelectorAll('.scard').forEach(card => {
    card.style.opacity = '0';
    card.style.transform = 'translateY(24px)';
    card.style.transition = 'opacity 0.7s cubic-bezier(0.23,1,0.32,1), transform 0.7s cubic-bezier(0.23,1,0.32,1), border-color 0.5s, box-shadow 0.5s';
    observer.observe(card);
  });

  // Expand roadmap cards into preview boxes
  const roadmapCards = document.querySelectorAll('.scard.coming_soon');

  function toggleRoadmapCard(targetCard) {
    const isExpanded = targetCard.classList.contains('expanded');

    roadmapCards.forEach(card => {
      if (card !== targetCard) {
        card.classList.remove('expanded');
        card.setAttribute('aria-expanded', 'false');
      }
    });

    targetCard.classList.toggle('expanded', !isExpanded);
    targetCard.setAttribute('aria-expanded', String(!isExpanded));
  }

  roadmapCards.forEach(card => {
    card.setAttribute('role', 'button');
    card.setAttribute('tabindex', '0');
    card.setAttribute('aria-expanded', 'false');

    card.addEventListener('click', () => toggleRoadmapCard(card));
    card.addEventListener('keydown', event => {
      if (event.key === 'Enter' || event.key === ' ') {
        event.preventDefault();
        toggleRoadmapCard(card);
      }
    });
  });
</script>
</body>
</html>