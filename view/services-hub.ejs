<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>CreatorOS — Unified Platform</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    :root {
      --bg: #020510;
      --bg2: #070d1f;
      --glass: rgba(8, 16, 38, 0.55);
      --glass2: rgba(12, 24, 52, 0.7);
      --border: rgba(99, 179, 237, 0.12);
      --border-lit: rgba(99, 179, 237, 0.4);
      --text: #e8f4ff;
      --muted: #7fa8c9;
      --dim: #3d5a74;
      --cyan: #22d3ee;
      --blue: #60a5fa;
      --indigo: #818cf8;
      --glow-c: rgba(34, 211, 238, 0.18);
      --glow-b: rgba(96, 165, 250, 0.12);
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }

    body {
      font-family: 'Inter', sans-serif;
      background: var(--bg);
      color: var(--text);
      min-height: 100vh;
      overflow-x: hidden;
    }

    /* ── MESH BACKGROUND ── */
    .mesh-bg {
      position: fixed;
      inset: 0;
      pointer-events: none;
      z-index: 0;
      overflow: hidden;
    }
    .mesh-bg::before {
      content: '';
      position: absolute;
      width: 900px; height: 900px;
      left: -200px; top: -200px;
      background: radial-gradient(ellipse, rgba(34,211,238,0.09) 0%, transparent 65%);
      border-radius: 50%;
      animation: meshDrift1 18s ease-in-out infinite;
    }
    .mesh-bg::after {
      content: '';
      position: absolute;
      width: 700px; height: 700px;
      right: -150px; top: 30%;
      background: radial-gradient(ellipse, rgba(96,165,250,0.08) 0%, transparent 65%);
      border-radius: 50%;
      animation: meshDrift2 22s ease-in-out infinite;
    }
    .mesh-blob3 {
      position: absolute;
      width: 500px; height: 500px;
      left: 40%; bottom: -100px;
      background: radial-gradient(ellipse, rgba(129,140,248,0.06) 0%, transparent 65%);
      border-radius: 50%;
      animation: meshDrift3 15s ease-in-out infinite;
    }
    @keyframes meshDrift1 { 0%,100%{transform:translate(0,0) scale(1)} 50%{transform:translate(60px,-40px) scale(1.07)} }
    @keyframes meshDrift2 { 0%,100%{transform:translate(0,0) scale(1)} 50%{transform:translate(-50px,60px) scale(1.05)} }
    @keyframes meshDrift3 { 0%,100%{transform:translate(0,0) scale(1)} 50%{transform:translate(30px,-60px) scale(1.08)} }

    /* ── GRID OVERLAY ── */
    .grid-overlay {
      position: fixed; inset: 0; pointer-events: none; z-index: 0;
      background-image:
        linear-gradient(rgba(99,179,237,0.025) 1px, transparent 1px),
        linear-gradient(90deg, rgba(99,179,237,0.025) 1px, transparent 1px);
      background-size: 48px 48px;
    }

    /* ── WRAPPER ── */
    .page { position: relative; z-index: 1; }
    .container { width: min(1200px, 100%); margin: 0 auto; padding: 0 2rem; }

    /* ── NAVBAR ── */
    nav {
      padding: 1.5rem 0;
      position: sticky; top: 0; z-index: 100;
    }
    .nav-inner {
      display: flex; align-items: center; justify-content: space-between;
      padding: 0.85rem 1.75rem;
      background: rgba(2, 5, 16, 0.7);
      backdrop-filter: blur(24px) saturate(1.5);
      border: 1px solid var(--border);
      border-radius: 999px;
      box-shadow: 0 4px 40px rgba(0,0,0,0.4), inset 0 1px 0 rgba(255,255,255,0.04);
    }
    .brand {
      display: flex; align-items: center; gap: 0.9rem;
      text-decoration: none; color: var(--text);
    }
    .brand-orb {
      width: 2.6rem; height: 2.6rem; border-radius: 12px;
      background: linear-gradient(135deg, #22d3ee 0%, #6366f1 100%);
      display: grid; place-items: center;
      font-family: 'Inter', sans-serif;
      font-weight: 800; font-size: 1.1rem; color: #fff;
      box-shadow: 0 0 20px rgba(34,211,238,0.35), 0 0 40px rgba(34,211,238,0.12);
      position: relative;
      animation: orbPulse 3s ease-in-out infinite;
    }
    @keyframes orbPulse {
      0%,100%{box-shadow:0 0 20px rgba(34,211,238,0.35),0 0 40px rgba(34,211,238,0.12)}
      50%{box-shadow:0 0 28px rgba(34,211,238,0.55),0 0 55px rgba(34,211,238,0.2)}
    }
    .brand-text strong {
      display: block; font-family: 'Inter', sans-serif;
      font-size: 1rem; font-weight: 700; letter-spacing: -0.02em;
    }
    .brand-text span {
      display: block; font-size: 0.72rem; color: var(--muted); font-weight: 400;
      letter-spacing: 0.04em; text-transform: uppercase;
    }
    .nav-links { display: flex; align-items: center; gap: 2rem; }
    .nav-links a {
      color: var(--muted); text-decoration: none; font-size: 0.88rem;
      font-weight: 500; letter-spacing: 0.01em;
      transition: color 0.2s;
    }
    .nav-links a:hover { color: var(--text); }
    .btn-signin {
      padding: 0.55rem 1.3rem;
      background: transparent;
      border: 1px solid rgba(34,211,238,0.35);
      border-radius: 999px;
      color: var(--cyan); font-size: 0.82rem; font-weight: 600;
      text-decoration: none;
      transition: all 0.25s;
      letter-spacing: 0.03em;
    }
    .btn-signin:hover {
      background: rgba(34,211,238,0.08);
      border-color: var(--cyan);
      box-shadow: 0 0 16px rgba(34,211,238,0.2);
    }

    /* ── HERO ── */
    .hero {
      padding: 1rem 0 4rem;
    }
    .hero-grid {
      display: grid;
      grid-template-columns: 1.2fr 0.8fr;
      gap: 1.5rem;
      align-items: stretch;
    }

    /* Hero left panel */
    .hero-panel {
      padding: 3.5rem;
      border-radius: 28px;
      background: var(--glass);
      border: 1px solid var(--border);
      backdrop-filter: blur(24px);
      position: relative;
      overflow: hidden;
      transform-style: preserve-3d;
      transition: transform 0.6s cubic-bezier(0.23,1,0.32,1), box-shadow 0.6s;
      box-shadow:
        0 30px 60px rgba(0,0,0,0.5),
        0 0 0 1px rgba(255,255,255,0.04) inset,
        0 1px 0 rgba(255,255,255,0.08) inset;
    }
    .hero-panel::before {
      content: '';
      position: absolute; inset: 0;
      background: radial-gradient(600px at 0% 0%, rgba(34,211,238,0.06), transparent 60%);
      pointer-events: none;
    }
    .hero-panel::after {
      content: '';
      position: absolute;
      top: -1px; left: 5%; right: 5%;
      height: 1px;
      background: linear-gradient(90deg, transparent, rgba(34,211,238,0.5), transparent);
    }

    .kicker {
      display: inline-flex; align-items: center; gap: 0.6rem;
      padding: 0.4rem 1rem; border-radius: 999px;
      background: rgba(34,211,238,0.07);
      border: 1px solid rgba(34,211,238,0.2);
      font-size: 0.75rem; font-weight: 600; letter-spacing: 0.08em;
      text-transform: uppercase; color: var(--cyan);
      margin-bottom: 2rem;
    }
    .kicker-dot {
      width: 6px; height: 6px; border-radius: 50%;
      background: var(--cyan);
      box-shadow: 0 0 8px var(--cyan);
      animation: blink 1.5s ease-in-out infinite;
    }
    @keyframes blink { 0%,100%{opacity:1} 50%{opacity:0.3} }

    .hero-panel h1 {
      font-family: 'Inter', sans-serif;
      font-size: clamp(2.4rem, 4vw, 3.2rem);
      font-weight: 800;
      line-height: 1.1;
      letter-spacing: -0.04em;
      color: #fff;
      margin-bottom: 1.25rem;
    }
    .hero-panel h1 .gradient-text {
      background: linear-gradient(135deg, #22d3ee 0%, #818cf8 50%, #60a5fa 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    .hero-panel p {
      color: var(--muted); line-height: 1.7; font-size: 1rem;
      max-width: 42ch; margin-bottom: 2.5rem; font-weight: 300;
    }
    .hero-actions { display: flex; gap: 1rem; flex-wrap: wrap; }

    .btn-primary {
      display: inline-flex; align-items: center; gap: 0.5rem;
      padding: 0.9rem 1.8rem; border-radius: 999px;
      background: linear-gradient(135deg, #22d3ee, #6366f1);
      color: #fff; font-weight: 600; font-size: 0.92rem;
      text-decoration: none; letter-spacing: 0.01em;
      box-shadow: 0 8px 24px rgba(34,211,238,0.25), 0 2px 4px rgba(0,0,0,0.3);
      transition: all 0.3s cubic-bezier(0.23,1,0.32,1);
      position: relative; overflow: hidden;
    }
    .btn-primary::before {
      content: '';
      position: absolute; inset: 0;
      background: linear-gradient(135deg, rgba(255,255,255,0.15), transparent);
      opacity: 0; transition: opacity 0.3s;
    }
    .btn-primary:hover {
      transform: translateY(-3px);
      box-shadow: 0 16px 36px rgba(34,211,238,0.38), 0 4px 8px rgba(0,0,0,0.3);
    }
    .btn-primary:hover::before { opacity: 1; }

    .btn-secondary {
      display: inline-flex; align-items: center; gap: 0.5rem;
      padding: 0.9rem 1.8rem; border-radius: 999px;
      border: 1px solid rgba(255,255,255,0.1);
      color: rgba(255,255,255,0.75); font-weight: 500; font-size: 0.92rem;
      text-decoration: none; background: rgba(255,255,255,0.03);
      transition: all 0.3s;
    }
    .btn-secondary:hover {
      transform: translateY(-2px);
      border-color: rgba(255,255,255,0.22);
      background: rgba(255,255,255,0.07);
      color: #fff;
    }

    /* ── ECOSYSTEM PANEL (3D Cards) ── */
    .ecosystem-panel {
      border-radius: 28px;
      background: rgba(4, 10, 25, 0.6);
      border: 1px solid var(--border);
      backdrop-filter: blur(20px);
      position: relative;
      overflow: hidden;
      min-height: 420px;
      box-shadow:
        0 30px 60px rgba(0,0,0,0.5),
        0 0 0 1px rgba(255,255,255,0.03) inset;
    }
    .ecosystem-panel::after {
      content: '';
      position: absolute;
      top: -1px; left: 10%; right: 10%;
      height: 1px;
      background: linear-gradient(90deg, transparent, rgba(96,165,250,0.4), transparent);
    }
    .eco-grid {
      position: absolute; inset: 0;
      background-image:
        linear-gradient(rgba(99,179,237,0.03) 1px, transparent 1px),
        linear-gradient(90deg, rgba(99,179,237,0.03) 1px, transparent 1px);
      background-size: 32px 32px;
    }
    .eco-glow {
      position: absolute;
      top: 30%; left: 30%;
      width: 300px; height: 300px;
      background: radial-gradient(circle, rgba(34,211,238,0.05), transparent 70%);
      pointer-events: none;
    }

    /* 3D floating cards */
    .card-stack {
      position: absolute; inset: 0;
      display: flex; align-items: center; justify-content: center;
      perspective: 800px;
    }
    .fc {
      position: absolute;
      border-radius: 14px;
      padding: 14px 18px;
      display: flex; align-items: center; gap: 12px;
      backdrop-filter: blur(12px);
      border: 1px solid rgba(255,255,255,0.08);
      box-shadow: 0 12px 32px rgba(0,0,0,0.5), inset 0 1px 0 rgba(255,255,255,0.07);
      cursor: default; user-select: none;
      transition: transform 0.35s cubic-bezier(0.23,1,0.32,1), box-shadow 0.35s;
      transform-origin: center;
    }
    .fc:hover {
      box-shadow: 0 20px 50px rgba(0,0,0,0.6), inset 0 1px 0 rgba(255,255,255,0.1);
      z-index: 20 !important;
    }
    .fc-icon {
      width: 36px; height: 36px; border-radius: 10px;
      display: grid; place-items: center; flex-shrink: 0;
    }
    .fc-icon svg { width: 18px; height: 18px; }
    .fc-name { font-family: 'Inter', sans-serif; font-size: 13px; font-weight: 700; color: #fff; white-space: nowrap; }
    .fc-tag {
      font-size: 9px; font-weight: 700; letter-spacing: 0.1em;
      text-transform: uppercase; padding: 2px 7px; border-radius: 999px;
    }
    .live { background: rgba(34,211,238,0.12); border: 1px solid rgba(34,211,238,0.25); color: var(--cyan); }
    .soon { background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08); color: var(--dim); }

    /* individual cards with 3D tilt positions */
    .fc-1 {
      background: linear-gradient(135deg, rgba(6,182,212,0.2), rgba(6,182,212,0.06));
      top: 10%; left: 6%;
      transform: rotateX(8deg) rotateY(-10deg) translateZ(0px);
      animation: float1 6s ease-in-out infinite;
      width: 200px;
    }
    .fc-2 {
      background: linear-gradient(135deg, rgba(99,102,241,0.2), rgba(99,102,241,0.06));
      top: 18%; right: 6%;
      transform: rotateX(6deg) rotateY(12deg) translateZ(20px);
      animation: float2 7.5s ease-in-out infinite;
      width: 195px;
    }
    .fc-3 {
      background: linear-gradient(135deg, rgba(16,185,129,0.2), rgba(16,185,129,0.06));
      top: 44%; left: 4%;
      transform: rotateX(-4deg) rotateY(-8deg) translateZ(10px);
      animation: float3 5.5s ease-in-out infinite;
      width: 190px;
    }
    .fc-4 {
      background: linear-gradient(135deg, rgba(245,158,11,0.18), rgba(245,158,11,0.05));
      top: 46%; right: 7%;
      transform: rotateX(-6deg) rotateY(10deg) translateZ(5px);
      animation: float4 8s ease-in-out infinite;
      width: 190px;
    }
    .fc-5 {
      background: linear-gradient(135deg, rgba(239,68,68,0.18), rgba(239,68,68,0.05));
      bottom: 12%; left: 12%;
      transform: rotateX(5deg) rotateY(-6deg) translateZ(15px);
      animation: float5 6.8s ease-in-out infinite;
      width: 195px;
    }
    .fc-6 {
      background: linear-gradient(135deg, rgba(168,85,247,0.18), rgba(168,85,247,0.05));
      bottom: 10%; right: 5%;
      transform: rotateX(7deg) rotateY(8deg) translateZ(0px);
      animation: float6 7s ease-in-out infinite;
      width: 190px;
    }

    @keyframes float1 { 0%,100%{transform:rotateX(8deg) rotateY(-10deg) translateZ(0px) translateY(0)} 50%{transform:rotateX(10deg) rotateY(-12deg) translateZ(8px) translateY(-10px)} }
    @keyframes float2 { 0%,100%{transform:rotateX(6deg) rotateY(12deg) translateZ(20px) translateY(0)} 50%{transform:rotateX(8deg) rotateY(14deg) translateZ(28px) translateY(-14px)} }
    @keyframes float3 { 0%,100%{transform:rotateX(-4deg) rotateY(-8deg) translateZ(10px) translateY(0)} 50%{transform:rotateX(-6deg) rotateY(-10deg) translateZ(18px) translateY(-8px)} }
    @keyframes float4 { 0%,100%{transform:rotateX(-6deg) rotateY(10deg) translateZ(5px) translateY(0)} 50%{transform:rotateX(-8deg) rotateY(12deg) translateZ(12px) translateY(-12px)} }
    @keyframes float5 { 0%,100%{transform:rotateX(5deg) rotateY(-6deg) translateZ(15px) translateY(0)} 50%{transform:rotateX(7deg) rotateY(-8deg) translateZ(22px) translateY(-9px)} }
    @keyframes float6 { 0%,100%{transform:rotateX(7deg) rotateY(8deg) translateZ(0px) translateY(0)} 50%{transform:rotateX(9deg) rotateY(10deg) translateZ(8px) translateY(-11px)} }

    /* ── SECTION HEADER ── */
    .section { padding: 5rem 0; }
    .section-eyebrow {
      display: flex; align-items: center; gap: 0.6rem; margin-bottom: 0.75rem;
    }
    .eyebrow-dot {
      width: 8px; height: 8px; border-radius: 50%; background: var(--cyan);
      box-shadow: 0 0 8px var(--cyan); animation: blink 1.5s ease-in-out infinite;
    }
    .eyebrow-text {
      font-size: 0.72rem; font-weight: 700; letter-spacing: 0.12em;
      text-transform: uppercase; color: var(--cyan);
    }
    .section-header {
      display: flex; align-items: flex-end; justify-content: space-between;
      gap: 2rem; flex-wrap: wrap;
      padding-bottom: 2.5rem;
      border-bottom: 1px solid rgba(99,179,237,0.08);
      margin-bottom: 3rem;
    }
    .section-header h2 {
      font-family: 'Inter', sans-serif;
      font-size: clamp(2rem, 3.5vw, 2.6rem);
      font-weight: 800; letter-spacing: -0.04em; color: #fff;
      line-height: 1.1;
    }
    .section-header p {
      color: var(--muted); font-size: 0.95rem; font-weight: 300;
      max-width: 38ch; line-height: 1.65;
    }

    /* ── TAB SWITCHER ── */
    .tab-bar {
      display: flex; gap: 4px; padding: 5px;
      background: rgba(255,255,255,0.03);
      border: 1px solid rgba(255,255,255,0.06);
      border-radius: 999px;
      box-shadow: inset 0 2px 8px rgba(0,0,0,0.3);
    }
    .tab-btn {
      padding: 0.55rem 1.25rem;
      border-radius: 999px; border: none;
      font-size: 0.78rem; font-weight: 700;
      letter-spacing: 0.05em; text-transform: uppercase;
      cursor: pointer; transition: all 0.25s;
      color: var(--dim); background: transparent;
    }
    .tab-btn.active {
      background: linear-gradient(135deg, #22d3ee, #6366f1);
      color: #fff;
      box-shadow: 0 4px 16px rgba(34,211,238,0.3);
    }
    .tab-btn:hover:not(.active) { color: var(--text); }

    /* ── SERVICE GRID ── */
    .services-grid {
      display: grid;
      grid-template-columns: repeat(6, minmax(0, 1fr));
      gap: 1.25rem;
    }
    .services-grid > .scard {
      grid-column: span 2;
    }
    .services-grid > .scard.coming_soon:nth-of-type(4) { grid-column: 1 / span 2; }
    .services-grid > .scard.coming_soon:nth-of-type(5) { grid-column: 3 / span 2; }
    .services-grid > .scard.coming_soon:nth-of-type(6) { grid-column: 5 / span 2; }
    .services-grid > .scard.coming_soon:nth-of-type(7) { grid-column: 2 / span 2; }
    .services-grid > .scard.coming_soon:nth-of-type(8) { grid-column: 4 / span 2; }
    .services-grid > .scard.coming_soon:nth-of-type(9) { grid-column: 3 / span 2; }

    /* ── SERVICE CARD (3D) ── */
    .scard {
      border-radius: 22px;
      padding: 2rem;
      position: relative; overflow: hidden;
      display: flex; flex-direction: column; gap: 0.9rem;
      transform-style: preserve-3d;
      perspective: 600px;
      transition: transform 0.5s cubic-bezier(0.23,1,0.32,1), box-shadow 0.5s;
      cursor: default;
    }
    .scard.available {
      background: linear-gradient(160deg, rgba(12,24,52,0.7) 0%, rgba(5,12,28,0.8) 100%);
      border: 1px solid rgba(34,211,238,0.12);
      box-shadow: 0 16px 40px rgba(0,0,0,0.4), inset 0 1px 0 rgba(255,255,255,0.05);
    }
    .scard.available:hover {
      transform: translateY(-8px) rotateX(4deg);
      border-color: rgba(34,211,238,0.35);
      box-shadow: 0 28px 60px rgba(0,0,0,0.5), 0 0 0 1px rgba(34,211,238,0.2), 0 -8px 32px rgba(34,211,238,0.08) inset;
    }
    .scard.coming_soon {
      background: linear-gradient(160deg, rgba(8,15,35,0.5) 0%, rgba(4,8,20,0.6) 100%);
      border: 1px solid rgba(255,255,255,0.05);
      box-shadow: 0 12px 30px rgba(0,0,0,0.3);
      opacity: 0.7;
      cursor: pointer;
    }
    .scard.coming_soon:hover { opacity: 0.9; transform: translateY(-4px); }
    .scard.coming_soon.expanded {
      opacity: 1;
      border-color: rgba(34,211,238,0.28);
      box-shadow: 0 18px 44px rgba(0,0,0,0.45), 0 0 0 1px rgba(34,211,238,0.12), inset 0 1px 0 rgba(255,255,255,0.06);
    }

    /* top edge glow line */
    .scard.available::before {
      content: '';
      position: absolute;
      top: 0; left: 10%; right: 10%; height: 1px;
      background: linear-gradient(90deg, transparent, rgba(34,211,238,0.5), transparent);
    }
    /* corner accent */
    .scard.available::after {
      content: '';
      position: absolute;
      top: 0; right: 0;
      width: 80px; height: 80px;
      background: radial-gradient(circle at top right, rgba(34,211,238,0.07), transparent 70%);
    }

    .card-top {
      display: flex; justify-content: space-between; align-items: flex-start;
    }
    .icon-box {
      width: 48px; height: 48px; border-radius: 14px;
      display: grid; place-items: center;
      transition: transform 0.35s cubic-bezier(0.23,1,0.32,1);
    }
    .scard.available .icon-box {
      background: rgba(34,211,238,0.07);
      border: 1px solid rgba(34,211,238,0.18);
      color: var(--cyan);
      box-shadow: 0 4px 16px rgba(34,211,238,0.08);
    }
    .scard.coming_soon .icon-box {
      background: rgba(255,255,255,0.03);
      border: 1px solid rgba(255,255,255,0.06);
      color: var(--dim);
    }
    .scard:hover .icon-box { transform: scale(1.1) rotate(6deg); }
    .icon-box svg { width: 22px; height: 22px; }

    .badge {
      display: inline-flex; align-items: center; gap: 5px;
      padding: 0.3rem 0.85rem; border-radius: 999px;
      font-size: 0.68rem; font-weight: 700; letter-spacing: 0.07em;
      text-transform: uppercase;
    }
    .badge.available {
      background: rgba(34,211,238,0.08);
      border: 1px solid rgba(34,211,238,0.2);
      color: var(--cyan);
    }
    .badge.coming_soon {
      background: rgba(255,255,255,0.03);
      border: 1px solid rgba(255,255,255,0.06);
      color: var(--dim);
    }
    .badge-pulse {
      width: 5px; height: 5px; border-radius: 50%;
      background: var(--cyan); animation: blink 1.5s ease-in-out infinite;
    }

    .scard h3 {
      font-family: 'Inter', sans-serif;
      font-size: 1.2rem; font-weight: 700;
      letter-spacing: -0.02em; color: #fff; line-height: 1.2;
    }
    .scard p {
      color: var(--muted); font-size: 0.88rem; line-height: 1.65;
      font-weight: 300; flex: 1;
    }

    .launch-btn {
      display: inline-flex; align-items: center; gap: 0.5rem;
      padding: 0.75rem 1.4rem; border-radius: 999px;
      background: linear-gradient(135deg, #22d3ee, #6366f1);
      color: #fff; font-weight: 600; font-size: 0.85rem;
      text-decoration: none; width: fit-content; margin-top: 0.5rem;
      box-shadow: 0 6px 20px rgba(34,211,238,0.2);
      transition: all 0.3s;
    }
    .launch-btn:hover {
      transform: translateY(-2px);
      box-shadow: 0 10px 28px rgba(34,211,238,0.32);
      filter: brightness(1.07);
    }
    .launch-btn svg { width: 16px; height: 16px; transition: transform 0.25s; }
    .launch-btn:hover svg { transform: translateX(3px); }

    .locked {
      display: inline-flex; align-items: center; gap: 0.5rem;
      padding: 0.75rem 0; color: var(--dim);
      font-size: 0.8rem; font-weight: 600;
      letter-spacing: 0.06em; text-transform: uppercase;
      margin-top: 0.5rem;
    }
    .locked svg { width: 14px; height: 14px; }

    .module-details {
      display: grid;
      gap: 0.7rem;
      max-height: 0;
      opacity: 0;
      overflow: hidden;
      transform: translateY(-4px);
      transition: max-height 0.45s cubic-bezier(0.23,1,0.32,1), opacity 0.3s ease, transform 0.3s ease;
    }
    .module-details h4 {
      font-size: 0.78rem;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--cyan);
    }
    .module-details ul {
      list-style: none;
      display: grid;
      gap: 0.5rem;
    }
    .module-details li {
      position: relative;
      padding-left: 1rem;
      color: var(--muted);
      font-size: 0.86rem;
      line-height: 1.6;
    }
    .module-details li::before {
      content: '•';
      position: absolute;
      left: 0;
      color: var(--cyan);
    }
    .scard.coming_soon.expanded .locked {
      display: none;
    }
    .scard.coming_soon.expanded .module-details {
      max-height: 220px;
      opacity: 1;
      transform: translateY(0);
    }

    /* ── STATS STRIP ── */
    .stats-strip {
      display: grid; grid-template-columns: repeat(3, 1fr);
      gap: 1px;
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.05);
      border-radius: 20px; overflow: hidden;
      margin: 4rem 0;
    }
    .stat-item {
      padding: 2.5rem 2rem; text-align: center;
      background: rgba(4,10,25,0.7);
      transition: background 0.3s;
    }
    .stat-item:hover { background: rgba(8,20,48,0.85); }
    .stat-num {
      font-family: 'Inter', sans-serif;
      font-size: 3rem; font-weight: 800;
      background: linear-gradient(135deg, #22d3ee, #818cf8);
      -webkit-background-clip: text; -webkit-text-fill-color: transparent;
      background-clip: text; line-height: 1;
      margin-bottom: 0.5rem;
    }
    .stat-label { color: var(--muted); font-size: 0.82rem; font-weight: 400; letter-spacing: 0.04em; }

    /* ── FOOTER ── */
    footer {
      border-top: 1px solid rgba(255,255,255,0.04);
      padding: 2.5rem 0; text-align: center;
      color: var(--dim); font-size: 0.82rem;
    }

    /* ── PAGE LOAD ANIMATIONS ── */
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(30px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    .anim { opacity: 0; animation: fadeUp 0.8s cubic-bezier(0.23,1,0.32,1) forwards; }
    .anim-1 { animation-delay: 0.1s; }
    .anim-2 { animation-delay: 0.2s; }
    .anim-3 { animation-delay: 0.32s; }
    .anim-4 { animation-delay: 0.45s; }
    .anim-5 { animation-delay: 0.58s; }

    /* responsive */
    @media (max-width: 960px) {
      .hero-grid { grid-template-columns: 1fr; }
      .services-grid { grid-template-columns: repeat(2, 1fr); }
      .services-grid > .scard {
        grid-column: auto !important;
        grid-row: auto !important;
      }
      .ecosystem-panel { min-height: 480px; }
    }
    @media (max-width: 600px) {
      .services-grid { grid-template-columns: 1fr; }
      .stats-strip { grid-template-columns: 1fr; }
      .hero-panel { padding: 2rem; }
      .nav-links { display: none; }
    }
  </style>
</head>
